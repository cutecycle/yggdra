# Normalize line endings for cross-platform consistency.
* text=auto eol=lf

# Vendor files must never have line endings converted — cargo verifies
# checksums against exact byte content, and any eol normalization breaks them.
vendor/** -text

# Binary files must never be converted
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp4 binary
*.webm binary
*.zip binary
*.tar binary
*.gz binary
*.tgz binary
